# Set this explicitly to your backend API base.
# Example (api-zk-accounting local): http://127.0.0.1:8000/api/v1
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# local (default) stores token in localStorage, cookie uses HttpOnly cookie
VITE_AUTH_TOKEN_MODE=local

# Optional industries API (expects a JSON array or { data: [...] })
VITE_INDUSTRIES_API=
